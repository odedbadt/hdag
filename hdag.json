{
  "children": {
    "reader":  {},
    "deduper": {},

    "validator": {
      "children": {
        "type_check":  {},
        "range_check": {},
        "null_check":  {},
        "rule_engine": {}
      },
      "dag": [
        ["validator->inputs->data",      "type_check->inputs->data"],
        ["type_check->outputs->valid",   "range_check->inputs->data"],
        ["range_check->outputs->valid",  "null_check->inputs->data"],
        ["null_check->outputs->valid",   "rule_engine->inputs->data"],
        ["type_check->outputs->invalid", "validator->outputs->invalid"],
        ["range_check->outputs->invalid","validator->outputs->invalid"],
        ["null_check->outputs->invalid", "validator->outputs->invalid"],
        ["rule_engine->outputs->valid",  "validator->outputs->valid"],
        ["rule_engine->outputs->invalid","validator->outputs->invalid"]
      ]
    },

    "translate": {
      "children": {
        "detector":   {},
        "translator": {},
        "quality":    {}
      },
      "dag": [
        ["translate->inputs->text",         "detector->inputs->text"],
        ["translate->inputs->text",         "translator->inputs->text"],
        ["translate->inputs->text",         "quality->inputs->text"],
        ["detector->outputs->lang",         "translator->inputs->lang"],
        ["translator->outputs->translated", "translate->outputs->translated"],
        ["detector->outputs->confidence",   "translate->outputs->confidence"],
        ["quality->outputs->approved",      "translate->outputs->approved"]
      ]
    },

    "nlp": {
      "children": {
        "tokenizer":  {},
        "embedder":   {},
        "classifier": {},
        "extractor":  {},
        "summarizer": {}
      },
      "dag": [
        ["nlp->inputs->text",           "tokenizer->inputs->text"],
        ["nlp->inputs->text",           "extractor->inputs->text"],
        ["nlp->inputs->text",           "summarizer->inputs->text"],
        ["tokenizer->outputs->tokens",  "embedder->inputs->tokens"],
        ["embedder->outputs->vectors",  "classifier->inputs->vectors"],
        ["classifier->outputs->label",  "nlp->outputs->label"],
        ["classifier->outputs->score",  "nlp->outputs->score"],
        ["extractor->outputs->entities","nlp->outputs->entities"],
        ["summarizer->outputs->summary","nlp->outputs->summary"]
      ]
    },

    "output": {
      "children": {
        "formatter": {},
        "db":        {},
        "cache":     {},
        "indexer":   {}
      },
      "dag": [
        ["output->inputs->data",     "formatter->inputs->data"],
        ["output->inputs->format",   "formatter->inputs->format"],
        ["formatter->outputs->output","db->inputs->data"],
        ["formatter->outputs->output","cache->inputs->data"],
        ["formatter->outputs->output","indexer->inputs->data"],
        ["db->outputs->done",        "output->outputs->db_done"],
        ["cache->outputs->done",     "output->outputs->cache_done"],
        ["indexer->outputs->done",   "output->outputs->indexed"]
      ]
    },

    "logger": {}
  },
  "dag": [
    ["root->inputs->path",           "reader->inputs->path"],
    ["root->inputs->format",         "output->inputs->format"],
    ["reader->outputs->raw",         "deduper->inputs->raw"],
    ["deduper->outputs->unique",     "validator->inputs->data"],
    ["deduper->outputs->duplicate",  "logger->inputs->msg"],
    ["validator->outputs->valid",    "translate->inputs->text"],
    ["validator->outputs->valid",    "nlp->inputs->text"],
    ["validator->outputs->invalid",  "logger->inputs->msg"],
    ["translate->outputs->translated","output->inputs->data"],
    ["nlp->outputs->label",          "output->inputs->data"],
    ["output->outputs->db_done",     "root->outputs->stored"],
    ["output->outputs->cache_done",  "root->outputs->cached"],
    ["output->outputs->indexed",     "root->outputs->indexed"],
    ["translate->outputs->confidence","root->outputs->quality"],
    ["logger->outputs->done",        "root->outputs->logged"]
  ]
}
