digraph GlobalDAG {
	bgcolor=white fontname=Helvetica newrank=true nodesep=0.6 rankdir=LR ranksep=1.4 splines=spline
	edge [arrowsize=0.7 color="#555555" fontname=Helvetica fontsize=9]
	SOURCE [label=SOURCE color="#2e7d32" fillcolor="#4caf50" fontcolor=white fontname="Helvetica Bold" shape=invhouse style=filled]
	SINK [label=SINK color="#bf360c" fillcolor="#e65100" fontcolor=white fontname="Helvetica Bold" shape=house style=filled]
	subgraph cluster_root {
		color="#3a7ebf" fillcolor="#e8f0fe" fontcolor="#3a7ebf" fontname="Helvetica Bold" fontsize=11 label="" penwidth=2 style="rounded,filled"
		subgraph "cluster_root.worker[0]" {
			color="#e65100" fillcolor="#fff3e0" fontcolor="#e65100" fontname="Helvetica Bold" fontsize=11 label="worker[0]" penwidth=2 style="rounded,filled"
			"root.worker[0].process" [label="worker[0].process" color="#e65100" fillcolor=white fontname=Helvetica fontsize=11 shape=box style="filled,rounded"]
			"root.worker[0].validate" [label="worker[0].validate" color="#e65100" fillcolor=white fontname=Helvetica fontsize=11 shape=box style="filled,rounded"]
		}
		subgraph "cluster_root.worker[1]" {
			color="#e65100" fillcolor="#fff3e0" fontcolor="#e65100" fontname="Helvetica Bold" fontsize=11 label="worker[1]" penwidth=2 style="rounded,filled"
			"root.worker[1].process" [label="worker[1].process" color="#e65100" fillcolor=white fontname=Helvetica fontsize=11 shape=box style="filled,rounded"]
		}
		{
			rank=same
			"root.worker[0].process"
			"root.worker[1].process"
		}
	}
	"root.worker[0].process":e -> "root.worker[0].validate":w [label="result→data"]
	SOURCE:e -> "root.worker[0].process":w [label="input→data"]
	SOURCE:e -> "root.worker[1].process":w [label="input→data"]
	"root.worker[0].validate":e -> SINK:w [label="ok→output"]
	"root.worker[1].process":e -> SINK:w [label="result→output"]
}
