digraph GlobalDAG {
	bgcolor=white fontname=Helvetica newrank=true nodesep=0.6 rankdir=LR ranksep=1.4 splines=spline
	edge [arrowsize=0.7 color="#555555" fontname=Helvetica fontsize=9]
	SOURCE [label=SOURCE color="#2e7d32" fillcolor="#4caf50" fontcolor=white fontname="Helvetica Bold" shape=invhouse style=filled]
	SINK [label=SINK color="#bf360c" fillcolor="#e65100" fontcolor=white fontname="Helvetica Bold" shape=house style=filled]
	subgraph cluster_root {
		color="#3a7ebf" fillcolor="#e8f0fe" fontcolor="#3a7ebf" fontname="Helvetica Bold" fontsize=11 label="" penwidth=2 style="rounded,filled"
		"root.ingest" [label=ingest color="#3a7ebf" fillcolor=white fontname=Helvetica fontsize=11 shape=box style="filled,rounded"]
		"root.branch_b" [label=branch_b color="#3a7ebf" fillcolor=white fontname=Helvetica fontsize=11 shape=box style="filled,rounded"]
		"root.join" [label=join color="#3a7ebf" fillcolor=white fontname=Helvetica fontsize=11 shape=box style="filled,rounded"]
		subgraph "cluster_root.branch_a" {
			color="#e65100" fillcolor="#fff3e0" fontcolor="#e65100" fontname="Helvetica Bold" fontsize=11 label=branch_a penwidth=2 style="rounded,filled"
			"root.branch_a.transform" [label="branch_a.transform" color="#e65100" fillcolor=white fontname=Helvetica fontsize=11 shape=box style="filled,rounded"]
			"root.branch_a.filter" [label="branch_a.filter" color="#e65100" fillcolor=white fontname=Helvetica fontsize=11 shape=box style="filled,rounded"]
		}
	}
	"root.branch_a.transform":e -> "root.branch_a.filter":w [label="out→data"]
	"root.ingest":e -> "root.branch_a.transform":w [label="out→data"]
	"root.ingest":e -> "root.branch_b":w [label="out→in"]
	"root.branch_a.filter":e -> "root.join":nw [label="out→left"]
	"root.branch_b":e -> "root.join":sw [label="out→right"]
	SOURCE:e -> "root.ingest":w [label="input→data"]
	"root.join":e -> SINK:w [label="result→output"]
}
