digraph GlobalDAG {
	bgcolor=white fontname=Helvetica newrank=true nodesep=0.6 rankdir=LR ranksep=1.4 splines=spline
	edge [arrowsize=0.7 color="#555555" fontname=Helvetica fontsize=9]
	SOURCE [label=SOURCE color="#2e7d32" fillcolor="#4caf50" fontcolor=white fontname="Helvetica Bold" shape=invhouse style=filled]
	SINK [label=SINK color="#bf360c" fillcolor="#e65100" fontcolor=white fontname="Helvetica Bold" shape=house style=filled]
	subgraph cluster_root {
		color="#3a7ebf" fillcolor="#e8f0fe" fontcolor="#3a7ebf" fontname="Helvetica Bold" fontsize=11 label="" penwidth=2 style="rounded,filled"
		subgraph "cluster_root.A" {
			color="#e65100" fillcolor="#fff3e0" fontcolor="#e65100" fontname="Helvetica Bold" fontsize=11 label=A penwidth=2 style="rounded,filled"
			"root.A.a1" [label="A.a1" color="#e65100" fillcolor=white fontname=Helvetica fontsize=11 shape=box style="filled,rounded"]
			"root.A.a2" [label="A.a2" color="#e65100" fillcolor=white fontname=Helvetica fontsize=11 shape=box style="filled,rounded"]
		}
		subgraph "cluster_root.B" {
			color="#e65100" fillcolor="#fff3e0" fontcolor="#e65100" fontname="Helvetica Bold" fontsize=11 label=B penwidth=2 style="rounded,filled"
			"root.B.b1" [label="B.b1" color="#e65100" fillcolor=white fontname=Helvetica fontsize=11 shape=box style="filled,rounded"]
			"root.B.b2" [label="B.b2" color="#e65100" fillcolor=white fontname=Helvetica fontsize=11 shape=box style="filled,rounded"]
		}
	}
	"root.A.a1":e -> "root.A.a2":w [label="y→x"]
	"root.B.b1":e -> "root.B.b2":w [label="y→x"]
	"root.A.a2":e -> "root.B.b1":w [label="y→x"]
	SOURCE:e -> "root.A.a1":w [label="input→x"]
	"root.B.b2":e -> SINK:w [label="y→output"]
}
