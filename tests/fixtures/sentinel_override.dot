digraph GlobalDAG {
	bgcolor=white fontname=Helvetica newrank=true nodesep=0.6 rankdir=LR ranksep=1.4 splines=spline
	edge [arrowsize=0.7 color="#555555" fontname=Helvetica fontsize=9]
	SOURCE [label=SOURCE color="#2e7d32" fillcolor="#4caf50" fontcolor=white fontname="Helvetica Bold" shape=invhouse style=filled]
	SINK [label=SINK color="#bf360c" fillcolor="#e65100" fontcolor=white fontname="Helvetica Bold" shape=house style=filled]
	subgraph cluster_root {
		color="#3a7ebf" fillcolor="#e8f0fe" fontcolor="#3a7ebf" fontname="Helvetica Bold" fontsize=11 label="" penwidth=2 style="rounded,filled"
		subgraph "cluster_root.validator" {
			color="#e65100" fillcolor="#fff3e0" fontcolor="#e65100" fontname="Helvetica Bold" fontsize=11 label=validator penwidth=2 style="rounded,filled"
			"root.validator.validator" [label="validator.validator" color="#e65100" fillcolor=white fontname=Helvetica fontsize=11 shape=box style="filled,rounded"]
			"root.validator.logger" [label="validator.logger" color="#e65100" fillcolor=white fontname=Helvetica fontsize=11 shape=box style="filled,rounded"]
		}
	}
	"root.validator.validator":e -> "root.validator.logger":w [label="valid→event"]
	SOURCE:e -> "root.validator.validator":w [label="in→data"]
	"root.validator.logger":e -> SINK:w [label="ack→out"]
}
