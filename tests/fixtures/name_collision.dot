digraph GlobalDAG {
	bgcolor=white fontname=Helvetica newrank=true nodesep=0.6 rankdir=LR ranksep=1.4 splines=spline
	edge [arrowsize=0.7 color="#555555" fontname=Helvetica fontsize=9]
	SOURCE [label=SOURCE color="#2e7d32" fillcolor="#4caf50" fontcolor=white fontname="Helvetica Bold" shape=invhouse style=filled]
	SINK [label=SINK color="#bf360c" fillcolor="#e65100" fontcolor=white fontname="Helvetica Bold" shape=house style=filled]
	subgraph cluster_root {
		color="#3a7ebf" fillcolor="#e8f0fe" fontcolor="#3a7ebf" fontname="Helvetica Bold" fontsize=11 label="" penwidth=2 style="rounded,filled"
		"root.input" [label=input color="#3a7ebf" fillcolor=white fontname=Helvetica fontsize=11 shape=box style="filled,rounded"]
		"root.output" [label=output color="#3a7ebf" fillcolor=white fontname=Helvetica fontsize=11 shape=box style="filled,rounded"]
		subgraph "cluster_root.A" {
			color="#e65100" fillcolor="#fff3e0" fontcolor="#e65100" fontname="Helvetica Bold" fontsize=11 label=A penwidth=2 style="rounded,filled"
			subgraph "cluster_root.A.B" {
				color="#2e7d32" fillcolor="#e8f5e9" fontcolor="#2e7d32" fontname="Helvetica Bold" fontsize=11 label="A.B" penwidth=2 style="rounded,filled"
				"root.A.B.A" [label="A.B.A" color="#2e7d32" fillcolor=white fontname=Helvetica fontsize=11 shape=box style="filled,rounded"]
				"root.A.B.tail" [label="A.B.tail" color="#2e7d32" fillcolor=white fontname=Helvetica fontsize=11 shape=box style="filled,rounded"]
			}
		}
	}
	"root.A.B.A":e -> "root.A.B.tail":w [label="y→z"]
	"root.input":e -> "root.A.B.A":w [label="out→x"]
	"root.A.B.tail":e -> "root.output":w [label="w→in"]
	SOURCE:e -> "root.input":w [label="source→in"]
	"root.output":e -> SINK:w [label="out→result"]
}
